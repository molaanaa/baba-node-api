# Gateway Configuration
NODE_IP=38.242.234.47
NODE_PORT=9090
# API_DIAG (apidiag.thrift) is normally exposed on a port distinct from the
# main API. Defaults to NODE_PORT; set this when GetActiveNodes / GetSupply
# / GetNodeInfo / GetActiveTransactionsCount return "Invalid method name".
NODE_DIAG_PORT=9090
DEBUG_LOGGING=False

# Security & Rate Limiting
REDIS_URL=redis://localhost:6379/0
WHITELIST_IPS=127.0.0.1

# Long-poll timeouts (milliseconds)
WAIT_DEFAULT_TIMEOUT_MS=30000
WAIT_MAX_TIMEOUT_MS=120000
